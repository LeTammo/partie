{% trans_default_domain 'mills' %}
<div class="mx-auto w-fit" data-controller="optimistic dragdrop--piece-move"
     data-dragdrop--piece-move-moves-value="{{ view.moves|json_encode|e('html_attr') }}"
     data-dragdrop--piece-move-choices-value="{{ view.choices|json_encode|e('html_attr') }}">

    <div class="mb-3 flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            {% embed 'components/player_banner.html.twig' with {p: p} %}
                {% block extra %}
                    <span class="text-sm font-extrabold text-warmgray-400">{{ p.pieces }}</span>
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    {% set banner = view.pendingRemoval
        ? 'mills.choose_removal'|trans
        : (view.opponentPendingRemoval
            ? 'mills.opponent_removing'|trans
            : (view.myTurn and view.phase == 'placing' ? 'mills.pieces_left'|trans({'%count%': view.placedRemaining}) : null)) %}
    <p class="mb-3 flex min-h-11 items-center justify-center rounded-2xl bg-terracotta-50 px-4 text-center text-sm font-extrabold text-terracotta-700 shadow-soft {{ banner is null ? 'invisible' }}">
        {{ banner }}
    </p>

    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" data-dragdrop--piece-move-target="form" class="hidden">
        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
        <input type="hidden" name="action" value="move">
        <input type="hidden" name="from" data-dragdrop--piece-move-target="from">
        <input type="hidden" name="to" data-dragdrop--piece-move-target="to">
        <input type="hidden" name="remove" data-dragdrop--piece-move-target="choice">
    </form>

    {% include 'components/board.html.twig' with {board: view.board} %}
</div>
