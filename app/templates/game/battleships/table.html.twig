{% trans_default_domain 'battleships' %}
<div class="space-y-6" data-controller="optimistic">
    {# ---------- players ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            {% embed 'components/player_banner.html.twig' with {p: p} %}
                {% block extra %}
                    <span class="text-sm font-extrabold text-warmgray-400">
                        {% if view.phase == 'placing' %}
                            {{ (p.ready ? 'battleships.ready' : 'battleships.placing')|trans }}
                        {% else %}
                            {{ 'battleships.hits'|trans({'%hits%': p.hits, '%total%': p.totalCells}) }}
                        {% endif %}
                    </span>
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    {% if view.phase == 'placing' and view.placing %}
        {# ---------- placement ---------- #}
        {% if not view.placing.ready %}
            <div data-controller="battleships--placement"
                 data-battleships--placement-shapes-value="{{ view.placing.shapes|json_encode|e('html_attr') }}"
                 data-battleships--placement-pool-value="{{ view.placing.pool|json_encode|e('html_attr') }}"
                 data-battleships--placement-occupied-value="{{ view.placing.occupied|json_encode|e('html_attr') }}"
                 data-battleships--placement-grid-width-value="{{ view.ownFleet.cols }}"
                 data-battleships--placement-grid-height-value="{{ view.ownFleet.rows }}">
                <div class="flex flex-wrap items-center justify-center gap-3">
                    <span class="text-sm font-extrabold text-warmgray-500">
                        {{ 'battleships.remaining'|trans({'%count%': view.placing.remaining}) }}
                    </span>
                    <button type="button" data-action="click->battleships--placement#rotate" class="btn btn-neutral cursor-pointer">
                        {{ 'battleships.rotate'|trans }}
                    </button>
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="randomize">
                        <button type="submit" class="btn btn-info cursor-pointer">{{ 'battleships.randomize'|trans }}</button>
                    </form>
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="reset">
                        <button type="submit" class="btn btn-neutral cursor-pointer">{{ 'battleships.reset'|trans }}</button>
                    </form>
                </div>

                <p class="mt-3 text-center text-xs font-extrabold uppercase tracking-wide text-warmgray-400">
                    {{ 'battleships.pick_a_shape'|trans }}
                </p>
                <div class="mt-2 flex flex-wrap items-center justify-center gap-2">
                    {% for entry in view.placing.pool|filter(e => not e.placed) %}
                        <button type="button"
                                data-battleships--placement-target="tray"
                                data-index="{{ entry.index }}"
                                data-action="click->battleships--placement#armFromTray"
                                title="{{ ('battleships.shape.' ~ entry.shape)|trans }}"
                                class="cursor-pointer grid place-items-center rounded-xl bg-white p-2 shadow-soft transition hover:shadow-lifted">
                            {% include 'components/shape_preview.html.twig' with {cells: view.placing.shapes[entry.shape][0], square: 8} only %}
                        </button>
                    {% endfor %}
                </div>

                <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}"
                      data-battleships--placement-target="form" class="hidden">
                    <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                    <input type="hidden" name="action" value="place">
                    <input type="hidden" name="index" data-battleships--placement-target="index">
                    <input type="hidden" name="x" data-battleships--placement-target="x">
                    <input type="hidden" name="y" data-battleships--placement-target="y">
                    <input type="hidden" name="orientation" data-battleships--placement-target="orientation">
                </form>

                <div class="mx-auto mt-4 w-fit" data-action="wheel->battleships--placement#wheel">
                    {% include 'components/board.html.twig' with {board: view.ownFleet} %}
                </div>
            </div>
        {% else %}
            <p class="text-center text-sm font-extrabold text-sage-600">{{ 'battleships.waiting_for_opponent'|trans }}</p>
            <div class="mx-auto w-fit">
                {% include 'components/board.html.twig' with {board: view.ownFleet} %}
            </div>
        {% endif %}
    {% endif %}

    {% if view.phase == 'battle' %}
        {# ---------- battle ---------- #}
        <p class="text-center text-sm font-extrabold {{ view.myTurn ? 'text-sage-600' : 'text-warmgray-400' }}">
            {{ (view.myTurn ? 'battleships.your_turn' : 'battleships.opponent_turn')|trans }}
        </p>
        <div class="flex flex-wrap items-start justify-center gap-6">
            <div class="text-center">
                <p class="mb-2 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'battleships.your_fleet'|trans }}</p>
                {% include 'components/board.html.twig' with {board: view.ownFleet} %}
            </div>
            <div class="text-center">
                <p class="mb-2 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'battleships.enemy_waters'|trans }}</p>
                {% include 'components/board.html.twig' with {board: view.targetGrid} %}
            </div>
        </div>
    {% endif %}
</div>
