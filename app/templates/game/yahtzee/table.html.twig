{% trans_default_domain 'yahtzee' %}
<div class="space-y-6" data-controller="optimistic">
    {# ---------- dice tray ---------- #}
    {% include 'components/dice_tray.html.twig' with {
        dice: view.dice,
        dieFace: view.dieFace,
        diePip: view.diePip,
        hasRolled: view.hasRolled,
        canRoll: view.canRoll,
        rollsLeft: view.rollsLeft,
        myTurn: view.myTurn,
    } %}

    {# ---------- scorecard ---------- #}
    {% include 'components/score_sheet.html.twig' with {
        rows: view.rows,
        players: view.players,
        domain: 'yahtzee',
        labelPrefix: 'yahtzee.category.',
        hintPrefix: 'yahtzee.hint.',
        canScore: view.canScore,
        inserts: {
            sixes: {title: 'yahtzee.upper_bonus'|trans, values: view.upperBonusValues},
        },
        totals: {title: 'yahtzee.total'|trans, values: view.totals},
    } %}
</div>
