{% trans_default_domain 'solitaire' %}
<div class="mx-auto max-w-4xl" data-controller="dragdrop--piece-move"
     data-dragdrop--piece-move-runs-value="true"
     data-dragdrop--piece-move-free-drag-value="true"
     data-dragdrop--piece-move-drag-highlight-value="foundation:"
     data-dragdrop--piece-move-moves-value="{{ view.moves|json_encode|e('html_attr') }}">
    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" data-dragdrop--piece-move-target="form" class="hidden">
        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
        <input type="hidden" name="action" value="move">
        <input type="hidden" name="from" data-dragdrop--piece-move-target="from">
        <input type="hidden" name="to" data-dragdrop--piece-move-target="to">
    </form>

    <div class="mb-6 flex flex-wrap items-start gap-3">
        {# stock #}
        {% include 'components/pile.html.twig' with {
            back: view.stockCount > 0,
            key: 'sol-stock',
            emptyIcon: 'chevron-down',
            emptyIconClass: 'size-5 rotate-180',
            emptyClass: 'border-warmgray-300 text-warmgray-300',
            form: {
                action: 'draw',
                title: (view.stockCount > 0 ? 'solitaire.stock' : 'solitaire.recycle')|trans,
                disabled: not view.canDraw,
            },
        } %}

        {# waste #}
        {% if view.waste %}
            {% include 'components/pile.html.twig' with {
                top: view.waste,
                key: 'sol-waste',
                flip: 'sol-' ~ view.waste.identity,
                buttonAttr: {
                    'data-dragdrop--piece-move-target': 'source',
                    'data-source': view.wasteSource,
                    draggable: 'true',
                    'data-action': 'click->dragdrop--piece-move#pick dragstart->dragdrop--piece-move#dragStart dragend->dragdrop--piece-move#dragEnd',
                },
            } only %}
        {% else %}
            {% include 'components/pile.html.twig' only %}
        {% endif %}

        <div class="ml-auto flex gap-3">
            {% for foundation in view.foundations %}
                {% include 'components/pile.html.twig' with {
                    top: foundation.top,
                    key: 'sol-fnd-' ~ foundation.zone,
                    flip: foundation.top ? 'sol-' ~ foundation.top.identity : null,
                    emptySymbol: foundation.suit,
                    emptyClass: 'border-warmgray-200 ' ~ (foundation.red ? 'text-terracotta-300' : 'text-warmgray-300'),
                    attr: {
                        'data-dragdrop--piece-move-target': 'zone',
                        'data-zone': foundation.zone,
                        'data-mode': 'replace',
                        title: 'solitaire.foundation'|trans,
                        'data-action': 'click->dragdrop--piece-move#pickZone dragover->dragdrop--piece-move#dragOver drop->dragdrop--piece-move#drop',
                    },
                } only %}
            {% endfor %}
        </div>
    </div>

    <div class="grid grid-cols-7 gap-3">
        {% for column in view.tableau %}
            <div data-dragdrop--piece-move-target="zone" data-zone="{{ column.zone }}"
                 data-action="click->dragdrop--piece-move#pickZone dragover->dragdrop--piece-move#dragOver drop->dragdrop--piece-move#drop"
                 class="min-h-24 -space-y-16">
                {% for card in column.cards %}
                    {% if not card.faceUp %}
                        {% include 'components/card.html.twig' with {back: true, key: 'sol-down-' ~ column.zone ~ '-' ~ loop.index0} only %}
                    {% else %}
                        <button type="button" data-dragdrop--piece-move-target="source" data-source="{{ card.source }}" draggable="true"
                                data-action="click->dragdrop--piece-move#pick dragstart->dragdrop--piece-move#dragStart dragend->dragdrop--piece-move#dragEnd"
                                class="block cursor-grab">
                            {% include 'components/card.html.twig' with card.card|merge({key: 'sol-' ~ card.card.identity, flip: 'sol-' ~ card.card.identity}) only %}
                        </button>
                    {% endif %}
                {% endfor %}
            </div>
        {% endfor %}
    </div>
</div>
