{% trans_default_domain 'checkers' %}
<div class="mx-auto w-fit"
     data-controller="dragdrop--piece-move"
     data-dragdrop--piece-move-moves-value="{{ view.moves|json_encode|e('html_attr') }}"
     data-dragdrop--piece-move-choices-value="{{ view.sacrificeSquares|json_encode|e('html_attr') }}"
     data-dragdrop--piece-move-capture-distance-value="2"
     data-dragdrop--piece-move-auto-select-value="true">

    {% set banner = view.mustContinue ? 'checkers.must_continue'|trans : (view.pendingSacrifice ? 'checkers.choose_sacrifice'|trans : null) %}
    <p class="mb-3 flex min-h-14 items-center justify-center rounded-2xl bg-terracotta-50 px-4 text-center text-base font-extrabold text-terracotta-700 shadow-soft {{ banner is null ? 'invisible' }}">
        {{ banner }}
    </p>

    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" data-dragdrop--piece-move-target="form" class="hidden">
        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
        <input type="hidden" name="from" data-dragdrop--piece-move-target="from">
        <input type="hidden" name="to" data-dragdrop--piece-move-target="to">
        <input type="hidden" name="sacrifice" data-dragdrop--piece-move-target="choice">
    </form>

    {% include 'components/board.html.twig' with {board: view.board} %}
</div>
