{% trans_default_domain 'blackjack' %}
<div class="space-y-6">
    {% if view.autoPending %}
        <div data-controller="autoplay"
             data-autoplay-url-value="{{ path('app_game_tick', {code: lobby.code}) }}"
             data-autoplay-token-value="{{ csrf_token('game') }}"
             data-autoplay-step-value="{{ view.autoStep }}"></div>
    {% endif %}
    {# ---------- dealer ---------- #}
    {% set dealerTitle = 'blackjack.round'|trans({'%round%': view.round, '%total%': view.roundsTotal}) ~ ' · ' ~ 'blackjack.dealer'|trans
        ~ (view.dealerUpValue is not null ? ' · ' ~ 'blackjack.shows'|trans({'%value%': view.dealerUpValue}) : '') %}
    {% embed 'components/table_area.html.twig' with {title: dealerTitle, active: view.dealerActing, dealerCards: view.dealer} %}
        {% block body %}
            <div class="flex justify-center gap-3">
                {% if dealerCards is empty %}
                    {% include 'components/card.html.twig' with {back: true, class: 'opacity-40'} only %}
                    {% include 'components/card.html.twig' with {back: true, class: 'opacity-40'} only %}
                {% else %}
                    {% for card in dealerCards %}
                        {% set cardKey = 'dealer-' ~ loop.index0 ~ '-' ~ (card.back|default(false) ? 'back' : card.identity) %}
                        {% include 'components/card.html.twig' with card|merge({key: cardKey, flip: cardKey}) only %}
                    {% endfor %}
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}

    {# ---------- players ---------- #}
    <div class="grid gap-3 sm:grid-cols-2 {{ view.players|length > 2 ? 'lg:grid-cols-3' }}">
        {% for p in view.players %}
            <div class="rounded-3xl bg-white p-4 shadow-soft transition {{ p.current ? 'ring-2 ring-softblue-300' }} {{ p.broke ? 'opacity-40' }}">
                {% embed 'components/player_banner.html.twig' with {p: p, variant: 'row'} %}
                    {% block extra %}
                        {% include 'components/chip_stack.html.twig' with {chips: p.chipStack, total: p.chips, size: 'size-5'} only %}
                    {% endblock %}
                {% endembed %}
                <div class="mt-3 flex min-h-24 flex-wrap gap-2">
                    {% for card in p.cards %}
                        {% set cardKey = 'seat-' ~ loop.parent.loop.index0 ~ '-' ~ loop.index0 ~ '-' ~ (card.back|default(false) ? 'back' : card.identity) %}
                        {% include 'components/card.html.twig' with card|merge({key: cardKey, flip: cardKey}) only %}
                    {% else %}
                        <p class="self-center text-sm font-bold text-warmgray-300">
                            {{ p.broke ? 'blackjack.broke'|trans : 'blackjack.waiting'|trans }}
                        </p>
                    {% endfor %}
                </div>
                <div class="mt-2 flex items-center justify-between text-sm font-extrabold">
                    <span class="text-warmgray-400">
                        {% if p.bet is not null %}{{ 'blackjack.bet_label'|trans({'%amount%': p.bet}) }}{% endif %}
                    </span>
                    {% if p.bust %}
                        <span class="anim-pop text-terracotta-500">{{ 'blackjack.bust'|trans }}</span>
                    {% elseif p.blackjack %}
                        <span class="anim-pop text-sunny-500">{{ 'blackjack.blackjack'|trans }}</span>
                    {% elseif p.value is not null %}
                        <span class="text-warmgray-600">{{ p.value }}</span>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# ---------- actions ---------- #}
    {% if view.myTurn %}
        <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="flex flex-wrap justify-center gap-3">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            {% if view.phase == 'betting' %}
                <input type="hidden" name="action" value="bet">
                {% for option in view.betOptions %}
                    <button type="submit" name="amount" value="{{ option.amount }}"
                            class="btn btn-neutral inline-flex items-center gap-2">
                        {% include 'components/chip.html.twig' with {color: option.chip.color, size: 'size-5'} only %}
                        {{ option.amount }}
                    </button>
                {% endfor %}
            {% else %}
                <button type="submit" name="action" value="hit" class="btn btn-primary">
                    {{ 'blackjack.hit'|trans }}
                </button>
                <button type="submit" name="action" value="stand" class="btn btn-neutral">
                    {{ 'blackjack.stand'|trans }}
                </button>
                {% if view.canDouble %}
                    <button type="submit" name="action" value="double" class="btn btn-info">
                        {{ 'blackjack.double'|trans }}
                    </button>
                {% endif %}
            {% endif %}
        </form>
    {% endif %}
</div>
