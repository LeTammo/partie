{% trans_default_domain 'maumau' %}
<div class="space-y-6" data-controller="optimistic dragdrop--zone-drop choice-dialog">
    {# ---------- players ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            {% embed 'components/player_banner.html.twig' with {p: p} %}
                {% block extra %}
                    <span class="inline-flex items-center gap-1 text-sm font-extrabold text-warmgray-400">
                        {% include 'icons/card-fan.svg.twig' with {class: 'size-4'} only %}
                        {{ p.cardCount }}
                    </span>
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    {# ---------- table: draw pile + discard ---------- #}
    {% embed 'components/table_area.html.twig' with {view: view, lobby: lobby} %}
        {% block body %}
            <div class="flex items-center justify-center gap-6">
                {% include 'components/pile.html.twig' with {
                    back: true,
                    key: 'mm-pile-back',
                    count: view.drawCount,
                    label: 'maumau.pile'|trans({'%count%': view.drawCount}),
                    form: {
                        action: 'draw',
                        title: 'maumau.draw'|trans,
                        disabled: not view.canDraw,
                        ghostFrom: '#mm-pile-back',
                        ghostTo: '#mm-handzone',
                    },
                    buttonAttr: view.canDraw ? {
                        draggable: 'true',
                        'data-pair': 'draw',
                        'data-dragdrop--zone-drop-target': 'source',
                        'data-action': 'dragstart->dragdrop--zone-drop#dragStart dragend->dragdrop--zone-drop#dragEnd',
                    } : {},
                } %}
                <div id="mm-dropzone" class="relative text-center"
                     data-dragdrop--zone-drop-target="zone" data-pair="play"
                     data-action="dragover->dragdrop--zone-drop#dragOver drop->dragdrop--zone-drop#drop dragleave->dragdrop--zone-drop#dragLeave">
                    {% include 'components/card.html.twig' with view.top|merge({
                        key: 'mm-top-' ~ view.top.identity,
                        flip: 'mm-' ~ view.top.identity,
                        exit: 'none',
                    }) only %}
                    <p class="mt-1.5 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'maumau.discard'|trans }}</p>

                    {# ---------- wish suit popout ---------- #}
                    <div id="mm-wish-dialog" class="hidden absolute left-1/2 top-full z-30 mt-3 w-max -translate-x-1/2">
                        <div class="relative rounded-3xl bg-white p-4 shadow-lifted">
                            <span class="absolute -top-1.5 left-1/2 size-3 -translate-x-1/2 rotate-45 rounded-sm bg-white"></span>
                            <div class="flex justify-center gap-2">
                                {% for suit in view.suits %}
                                    <button type="button" data-action="choice-dialog#pick" data-choice-dialog-value-param="{{ suit.value }}"
                                            title="{{ 'maumau.wish'|trans }} {{ suit.symbol }}"
                                            class="grid size-12 place-items-center rounded-2xl bg-cream text-2xl font-extrabold shadow-soft transition hover:shadow-lifted
                                                   {{ suit.red ? 'text-terracotta-500' : 'text-warmgray-800' }}">
                                        {{ suit.symbol }}
                                    </button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 flex flex-wrap items-center justify-center gap-3 text-base font-extrabold">
                {% if view.wishedSuit is not null %}
                    <span class="anim-pop rounded-xl bg-white px-3 py-1.5 shadow-soft {{ view.wishedSuitRed ? 'text-terracotta-500' : 'text-warmgray-800' }}">
                        {{ 'maumau.wished'|trans }} {{ view.wishedSuit }}
                    </span>
                {% endif %}
                {% if view.pendingDraw > 0 %}
                    <span id="pending-draw-{{ view.pendingDraw }}" class="anim-pop rounded-xl bg-terracotta-100 px-3 py-1.5 text-terracotta-700 shadow-soft">
                        {{ (view.penaltyLocked ? 'maumau.pending_draw_locked' : 'maumau.pending_draw')|trans({'%count%': view.pendingDraw}) }}
                    </span>
                {% endif %}
                {% if view.pendingSkip > 0 %}
                    <span id="pending-skip-{{ view.pendingSkip }}" class="anim-pop rounded-xl bg-softblue-100 px-3 py-1.5 text-softblue-700 shadow-soft">
                        {{ 'maumau.pending_skip'|trans({'%count%': view.pendingSkip}) }}
                    </span>
                {% endif %}
            </div>
        {% endblock %}
    {% endembed %}

    {# ---------- own hand ---------- #}
    {% if view.hand is not empty %}
        <div>
            <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'maumau.your_hand'|trans }}</p>
            <div id="mm-handzone" class="flex flex-wrap justify-center gap-3 rounded-2xl transition"
                 data-dragdrop--zone-drop-target="zone" data-pair="draw"
                 data-action="dragover->dragdrop--zone-drop#dragOver drop->dragdrop--zone-drop#drop dragleave->dragdrop--zone-drop#dragLeave">
                {% for card in view.hand %}
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="text-center"
                          data-action="submit->optimistic#move {{ card.isJack ? 'submit->choice-dialog#require' }}"
                          data-optimistic-to-param="#mm-dropzone" data-optimistic-id-param="mm-top-{{ card.identity }}"
                          {% if card.isJack %}
                              data-choice-dialog-dialog-param="#mm-wish-dialog" data-choice-dialog-name-param="wish"
                          {% endif %}>
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="play">
                        <input type="hidden" name="card" value="{{ card.index }}">
                        {% if card.isJack %}<input type="hidden" name="wish" value="">{% endif %}
                        <button type="submit"
                                {% if not card.playable %}disabled{% endif %}
                                {% if card.playable %}
                                    draggable="true" data-pair="play"
                                    data-dragdrop--zone-drop-target="source"
                                    data-action="dragstart->dragdrop--zone-drop#dragStart dragend->dragdrop--zone-drop#dragEnd"
                                {% endif %}
                                class="block rounded-xl transition enabled:cursor-grab enabled:hover:-translate-y-1.5 enabled:hover:shadow-lifted
                                       {{ not card.playable and view.myTurn ? 'opacity-40' }}
                                       {{ card.playable and card.isJack ? 'ring-2 ring-sunny-300' }}">
                            {% include 'components/card.html.twig' with card|merge({
                                key: 'mm-hand-' ~ card.identity,
                                flip: 'mm-' ~ card.identity,
                                exit: 'none',
                            }) only %}
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ---------- actions ---------- #}
    {% if view.canPass %}
        <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="text-center">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            <input type="hidden" name="action" value="pass">
            <button type="submit" class="btn btn-neutral">
                {{ 'maumau.pass'|trans }}
            </button>
        </form>
    {% endif %}
</div>
