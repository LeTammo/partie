{% trans_default_domain 'poker' %}
<div class="space-y-6">
    {% if view.autoPending %}
        <div data-controller="autoplay"
             data-autoplay-url-value="{{ path('app_game_tick', {code: lobby.code}) }}"
             data-autoplay-token-value="{{ csrf_token('game') }}"
             data-autoplay-step-value="{{ view.autoStep }}"></div>
    {% endif %}

    {# ---------- community + pot ---------- #}
    {% embed 'components/table_area.html.twig' with {title: 'poker.pot'|trans({'%amount%': view.pot}), active: view.phase in ['dealflop', 'dealturn', 'dealriver', 'showdown']} %}
        {% block body %}
            <div class="flex min-h-24 flex-wrap items-center justify-center gap-2">
                {% for card in view.community %}
                    {% set cardKey = 'pk-board-' ~ loop.index0 ~ '-' ~ card.identity %}
                    {% include 'components/card.html.twig' with card|merge({key: cardKey, flip: cardKey}) only %}
                {% else %}
                    <p class="text-sm font-bold text-warmgray-300">{{ 'poker.no_community'|trans }}</p>
                {% endfor %}
            </div>
            {% if view.results is not empty %}
                <div class="mt-3 flex flex-wrap justify-center gap-2">
                    {% for result in view.results %}
                        <span class="anim-pop rounded-xl bg-sunny-100 px-3 py-1.5 text-sm font-extrabold text-sunny-700 shadow-soft">
                            {{ 'poker.won_pot'|trans({'%player%': result.player, '%amount%': result.amount}) }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {# ---------- players ---------- #}
    <div class="grid gap-3 sm:grid-cols-2 {{ view.players|length > 2 ? 'lg:grid-cols-3' }}">
        {% for p in view.players %}
            <div class="rounded-3xl bg-white p-4 shadow-soft transition {{ p.current ? 'ring-2 ring-softblue-300' }} {{ p.folded or p.busted ? 'opacity-40' }}">
                {% embed 'components/player_banner.html.twig' with {p: p, variant: 'row'} %}
                    {% block extra %}
                        {% if p.allIn %}<span class="text-sm font-extrabold text-rose-500">{{ 'poker.all_in'|trans }}</span>
                        {% elseif p.bet > 0 %}<span class="text-sm font-extrabold text-warmgray-500">{{ 'poker.bet_label'|trans({'%amount%': p.bet}) }}</span>{% endif %}
                    {% endblock %}
                {% endembed %}
                <div class="mt-3 flex min-h-20 flex-wrap gap-2">
                    {% for card in p.cards %}
                        {% set cardKey = 'seat-' ~ loop.parent.loop.index0 ~ '-' ~ loop.index0 ~ '-' ~ (card.back|default(false) ? 'back' : card.identity) %}
                        {% include 'components/card.html.twig' with card|merge({size: 'sm', key: cardKey, flip: cardKey}) only %}
                    {% else %}
                        <p class="self-center text-sm font-bold text-warmgray-300">
                            {{ p.busted ? 'poker.busted'|trans : (p.folded ? 'poker.folded'|trans : 'poker.waiting'|trans) }}
                        </p>
                    {% endfor %}
                </div>
                <div class="mt-2 flex items-center justify-between text-sm font-extrabold text-warmgray-500">
                    <span>{{ p.isDealer ? 'poker.dealer_badge'|trans : '' }}</span>
                    {% include 'components/chip_stack.html.twig' with {chips: p.chipStack, total: p.chips, size: 'size-5'} only %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# ---------- actions ---------- #}
    {% if view.canStartNextRound %}
        <div class="flex justify-center">
            <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                <input type="hidden" name="action" value="next_round">
                <button type="submit" class="btn btn-primary">{{ 'poker.next_round'|trans }}</button>
            </form>
        </div>
    {% endif %}

    {% if view.myTurn %}
        <div class="flex flex-wrap items-center justify-center gap-3">
            <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                <input type="hidden" name="action" value="fold">
                <button type="submit" class="btn btn-muted cursor-pointer">{{ 'poker.fold'|trans }}</button>
            </form>
            <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                <input type="hidden" name="action" value="call">
                <button type="submit" class="btn btn-confirm cursor-pointer">
                    {{ view.canCheck ? 'poker.check'|trans : 'poker.call'|trans({'%amount%': view.callAmount}) }}
                </button>
            </form>
            {% if view.canRaise %}
                {% for option in view.betOptions %}
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="raise">
                        <input type="hidden" name="to" value="{{ option }}">
                        <button type="submit" class="btn btn-primary">{{ 'poker.raise_to_amount'|trans({'%amount%': option}) }}</button>
                    </form>
                {% endfor %}
                <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}"
                      class="flex items-center overflow-hidden rounded-2xl btn-primary shadow-soft">
                    <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                    <input type="hidden" name="action" value="raise">
                    <button type="submit" class="btn btn-primary cursor-pointer pl-7 pr-2">{{ 'poker.raise_to'|trans }}</button>
                    <input name="to" min="{{ view.minRaiseTo }}" max="{{ view.maxRaiseTo }}" value="" placeholder="0"
                           class="w-14 border-0 bg-transparent pl-1 py-2 font-bold focus:outline-none focus:ring-0">
                </form>
                <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                    <input type="hidden" name="action" value="allin">
                    <button type="submit" class="btn btn-danger cursor-pointer">{{ 'poker.all_in'|trans }}</button>
                </form>
            {% endif %}
        </div>
    {% endif %}
</div>
