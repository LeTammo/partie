{% trans_default_domain 'rummy' %}
<div class="space-y-6" data-controller="cards optimistic">
    {# ---------- players ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            {% embed 'components/player_banner.html.twig' with {p: p} %}
                {% block extra %}
                    <span class="inline-flex items-center gap-1 text-sm font-extrabold text-warmgray-400">
                        {% include 'icons/card-fan.svg.twig' with {class: 'size-4'} only %}
                        {{ p.cardCount }}
                    </span>
                    {% if p.hasMelded %}
                        <span class="text-xs font-extrabold uppercase tracking-wide text-sage-600">{{ 'rummy.opened'|trans }}</span>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    {# ---------- stock & discard ---------- #}
    {% embed 'components/table_area.html.twig' %}
        {% block body %}
            <div class="flex items-center justify-center gap-6">
                {% include 'components/pile.html.twig' with {
                    back: true,
                    key: 'rm-pile-back',
                    label: 'rummy.stock'|trans({'%count%': view.stockCount}),
                    form: {
                        action: 'draw',
                        title: 'rummy.draw'|trans,
                        disabled: not view.canDraw,
                        ghostFrom: '#rm-pile-back',
                        ghostTo: '#rm-hand',
                    },
                } %}
                {% include 'components/pile.html.twig' with {
                    top: view.discardTop,
                    key: view.discardTop is not null ? 'rm-top-' ~ view.discardTop.identity : null,
                    exit: 'none',
                    label: 'rummy.discard'|trans,
                    form: view.discardTop is not null ? {
                        action: 'takediscard',
                        title: 'rummy.take_discard'|trans,
                        disabled: not view.canDraw,
                    } : null,
                } %}
            </div>
        {% endblock %}
    {% endembed %}

    {# ---------- melds on the table ---------- #}
    {% if view.melds is not empty %}
        <div class="space-y-3">
            <p class="text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'rummy.melds'|trans }}</p>
            <div class="flex flex-wrap justify-center gap-4">
                {% for meld in view.melds %}
                    <div class="rounded-2xl bg-white p-3 shadow-soft">
                        <div class="flex gap-1.5">
                            {% for card in meld.cards %}
                                {% include 'components/card.html.twig' with card|merge({size: 'sm'}) only %}
                            {% endfor %}
                            {% if view.canLayoff %}
                                <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="self-center">
                                    <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                                    <input type="hidden" name="action" value="layoff">
                                    <input type="hidden" name="meld" value="{{ meld.key }}">
                                    <input type="hidden" name="cards" data-cards-target="input">
                                    <button type="submit" title="{{ 'rummy.layoff'|trans }}"
                                            class="flex size-8 items-center justify-center rounded-xl bg-sage-100 font-extrabold text-sage-700 shadow-soft transition hover:bg-sage-200 hover:shadow-lifted">
                                        +
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                        <p class="mt-1.5 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">
                            {{ meld.owner }} · {{ ('rummy.type_' ~ meld.type)|trans }}
                        </p>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ---------- own hand ---------- #}
    {% if view.hand is not empty %}
        <div>
            <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">
                {{ 'rummy.your_hand'|trans }}
                {% if not view.hasOpened %}
                    · {{ 'rummy.initial_progress'|trans({'%points%': view.initialPoints, '%needed%': view.initialMeldPoints}) }}
                {% endif %}
            </p>
            <div id="rm-hand" class="flex flex-wrap justify-center gap-2">
                {% for card in view.hand %}
                    <button type="button" data-cards-target="card" data-index="{{ card.index }}"
                            data-action="cards#toggle" {% if not view.canAct %}disabled{% endif %}
                            class="block rounded-xl transition">
                        {% include 'components/card.html.twig' with card only %}
                    </button>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ---------- actions ---------- #}
    {% if view.canAct %}
        <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="flex flex-wrap justify-center gap-3">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            <input type="hidden" name="cards" data-cards-target="input">
            <button type="submit" name="action" value="meld" class="btn btn-neutral">
                {{ 'rummy.meld'|trans }}
            </button>
            <button type="submit" name="action" value="discard" class="btn btn-primary">
                {{ 'rummy.discard_action'|trans }}
            </button>
            {% if view.canTakeback %}
                <button type="submit" name="action" value="takeback" class="btn btn-info">
                    {{ 'rummy.takeback'|trans }}
                </button>
            {% endif %}
        </form>
    {% endif %}
</div>
