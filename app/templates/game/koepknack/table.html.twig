{% trans_default_domain 'koepknack' %}
<div class="space-y-6" data-controller="dragdrop--group-swap"
     data-dragdrop--group-swap-id-template-value="kk-{group}-{slot}-{identity}">
    {# ---------- players & points ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            {% embed 'components/player_banner.html.twig' with {p: p, variant: 'tile'} %}
                {% block extra %}
                    <p class="mt-1 text-xs font-extrabold uppercase tracking-wide text-softblue-500">
                        {{ 'koepknack.points'|trans({'%points%': p.points}) }}
                    </p>
                {% endblock %}
            {% endembed %}
        {% endfor %}
    </div>

    {% if view.closed and not view.roundEnd %}
        <p class="anim-rise rounded-2xl bg-sunny-100 px-4 py-2.5 text-center text-base font-extrabold text-warmgray-700">
            {{ 'koepknack.closed_by'|trans({'%player%': view.closerName}) }}
        </p>
    {% endif %}

    {# ---------- round-end reveal ---------- #}
    {% if view.roundEnd %}
        {% embed 'components/table_area.html.twig' with {
            tone: 'accent',
            rise: true,
            title: 'koepknack.reveal'|trans,
            class: 'space-y-4 text-center',
        } %}
            {% block body %}
                <div class="flex flex-wrap justify-center gap-4">
                    {% for p in view.reveal %}
                        <div class="rounded-2xl bg-white p-3 shadow-soft">
                            <p class="mb-2 flex items-center justify-center gap-1.5 text-sm font-extrabold text-warmgray-700">
                                <span class="size-2.5 rounded-full" style="background-color: {{ p.color }}"></span>
                                {{ p.nickname }} · {{ 'koepknack.value'|trans({'%value%': p.value}) }}
                            </p>
                            <div class="flex justify-center gap-1.5">
                                {% for card in p.cards %}
                                    {% include 'components/card.html.twig' with card|merge({size: 'sm'}) only %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
                {% if view.canStartNewRound %}
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="mt-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="newround">
                        <button type="submit" class="btn btn-confirm">
                            {{ 'koepknack.new_round'|trans }}
                        </button>
                    </form>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}

    {% if not view.roundEnd %}
    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="space-y-6"
          data-action="submit->dragdrop--group-swap#beforeSubmit">
        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">

        {# ---------- middle cards ---------- #}
        {% embed 'components/table_area.html.twig' with {
            title: 'koepknack.round'|trans({'%round%': view.round, '%total%': view.roundsTotal}) ~ ' · ' ~ 'koepknack.middle'|trans,
        } %}
            {% block body %}
                <div class="flex justify-center gap-3">
                    {% for card in view.middle %}
                        <label class="{{ view.canAct ? 'cursor-pointer' }}" data-dragdrop--group-swap-target="item" data-slot="{{ loop.index0 }}"
                               {% if view.canAct %}draggable="true"{% endif %}
                               data-action="dragstart->dragdrop--group-swap#dragStart dragend->dragdrop--group-swap#dragEnd
                                            dragover->dragdrop--group-swap#dragOver drop->dragdrop--group-swap#drop dragleave->dragdrop--group-swap#dragLeave">
                            <input type="radio" name="middle" value="{{ loop.index0 }}" class="peer sr-only"
                                   {% if not view.canAct %}disabled{% endif %}>
                            <span class="block rounded-xl transition peer-checked:-translate-y-1.5 peer-checked:ring-4 peer-checked:ring-softblue-300">
                                {% include 'components/card.html.twig' with card|merge({
                                    key: 'kk-middle-' ~ loop.index0 ~ '-' ~ card.identity,
                                    flip: 'kk-' ~ card.identity,
                                    exit: ['fly-left', 'fade', 'fly-right'][loop.index0 % 3],
                                }) only %}
                            </span>
                        </label>
                    {% endfor %}
                </div>
            {% endblock %}
        {% endembed %}

        {# ---------- own hand ---------- #}
        {% if view.hand is not null %}
            <div>
                <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">
                    {{ 'koepknack.your_hand'|trans }} · {{ 'koepknack.value'|trans({'%value%': view.handValue}) }}
                </p>
                <div class="flex justify-center gap-3">
                    {% for card in view.hand %}
                        <label class="{{ view.canAct ? 'cursor-pointer' }}" data-dragdrop--group-swap-target="item" data-slot="{{ loop.index0 }}"
                               {% if view.canAct %}draggable="true"{% endif %}
                               data-action="dragstart->dragdrop--group-swap#dragStart dragend->dragdrop--group-swap#dragEnd
                                            dragover->dragdrop--group-swap#dragOver drop->dragdrop--group-swap#drop dragleave->dragdrop--group-swap#dragLeave">
                            <input type="radio" name="hand" value="{{ loop.index0 }}" class="peer sr-only"
                                   {% if not view.canAct %}disabled{% endif %}>
                            <span class="block rounded-xl transition peer-checked:-translate-y-1.5 peer-checked:ring-4 peer-checked:ring-sage-300">
                                {% include 'components/card.html.twig' with card|merge({
                                    key: 'kk-hand-' ~ loop.index0 ~ '-' ~ card.identity,
                                    flip: 'kk-' ~ card.identity,
                                    exit: ['fly-right', 'fade', 'fly-left'][loop.index0 % 3],
                                }) only %}
                            </span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# ---------- actions ---------- #}
        {% if view.canAct %}
            <div class="flex flex-wrap justify-center gap-3">
                <button type="submit" name="action" value="swap" data-dragdrop--group-swap-target="submitButton" class="btn btn-primary">
                    {{ 'koepknack.swap'|trans }}
                </button>
                <button type="submit" name="action" value="swapall" data-dragdrop--group-swap-target="swapAllButton" class="btn btn-neutral">
                    {{ 'koepknack.swap_all'|trans }}
                </button>
                <button type="submit" name="action" value="pass" class="btn btn-neutral">
                    {{ 'koepknack.pass'|trans }}
                </button>
                {% if view.canClose %}
                    <button type="submit" name="action" value="close" class="btn btn-info">
                        {{ 'koepknack.close'|trans }}
                    </button>
                {% endif %}
            </div>
        {% endif %}
    </form>
    {% endif %}
</div>
