<div class="rounded-3xl bg-white p-5 shadow-soft">
    <h3 class="text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'players.title'|trans }}</h3>
    <ul class="mt-3 space-y-2">
        {% for player in lobby.players %}
            {% set isTurn = lobby.state is not null
                and lobby.state.status.value == 'running'
                and lobby.state.currentPlayer.id == player.id %}
            <li class="flex items-center gap-3 rounded-2xl px-3 py-2 transition {{ isTurn ? 'bg-softblue-50 ring-2 ring-softblue-200' : 'bg-cream' }}">
                <span class="size-3.5 shrink-0 rounded-full" style="background-color: {{ player.color }}"></span>
                <span class="truncate font-bold">
                    {% if me is defined and me is not null and me.id == player.id %}
                        <span data-controller="nickname" data-nickname-name-value="{{ player.nickname }}" class="p-1 inline-flex items-center gap-1.5 align-middle">
                            <span data-nickname-target="display" class="inline-flex items-center gap-1">
                                <span data-nickname-target="text">{{ player.nickname }}</span>
                                <button type="button" data-action="nickname#edit"
                                        class="text-warmgray-300 transition hover:text-warmgray-500">
                                    {% include 'icons/pencil.svg.twig' with {class: 'size-4.5'} only %}
                                </button>
                            </span>
                            <form method="post" action="{{ path('app_lobby_rename', {code: lobby.code}) }}"
                                  data-nickname-target="form" data-action="submit->nickname#save" style="display: none"
                                  class="inline-flex items-center gap-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('lobby') }}">
                                <input type="text" name="nickname" data-nickname-target="input" maxlength="26" required
                                       data-action="keydown.esc->nickname#cancel blur->nickname#cancel"
                                       class="w-24 rounded-lg bg-white px-2 py-0.5 text-sm font-bold inset-shadow-soft focus:outline-none focus:ring-2 focus:ring-softblue-300">
                            </form>
                        </span>
                    {% else %}
                        {{ player.nickname }}
                    {% endif %}
                    {% if me is defined and me is not null and me.id == player.id %}
                        <span class="text-warmgray-400">{{ 'players.you'|trans }}</span>
                    {% endif %}
                </span>
                <span class="ml-auto flex items-center gap-1.5">
                    {% if lobby.roundWins is not empty %}
                        <span title="{{ 'lobby.rounds_won'|trans({'%count%': lobby.roundWins[player.id] ?? 0}) }}"
                              class="inline-flex items-center gap-0.5 text-xs font-extrabold text-sage-600">
                            {% include 'icons/trophy.svg.twig' with {class: 'size-3.5'} only %}
                            {{ lobby.roundWins[player.id] ?? 0 }}
                        </span>
                    {% endif %}
                    {% if lobby.isHost(player.id) %}
                        <span title="{{ 'players.host'|trans }}" class="text-softblue-300">
                            {% include 'icons/star.svg.twig' with {class: 'size-4'} only %}
                        </span>
                    {% endif %}
                    {% if isTurn %}
                        <span title="{{ 'players.turn'|trans }}" class="text-softblue-500">
                            {% include 'icons/target.svg.twig' with {class: 'size-4'} only %}
                        </span>
                    {% endif %}
                    {% if lobby.state is not null and lobby.state.winnerId == player.id %}
                        <span title="{{ 'players.winner'|trans }}" class="text-sage-500">
                            {% include 'icons/trophy.svg.twig' with {class: 'size-4'} only %}
                        </span>
                    {% endif %}
                </span>
            </li>
        {% endfor %}
    </ul>
</div>
