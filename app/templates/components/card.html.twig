{# How to use, see
   docs/components/cards.md #}
{% set base = 'anim-deal relative flex h-24 w-16 shrink-0 select-none flex-col rounded-xl shadow-soft ' ~ class|default('') %}
{% set id = key|default(null) %}
{% set attrs %}{% if id %} id="{{ id }}"{% endif %}{% if flip|default(null) %} data-flip-id="{{ flip }}"{% endif %}{% if exit|default(null) %} data-flip-exit="{{ exit }}"{% endif %}{% endset %}
{% if back|default(false) %}
    <span{{ attrs }} class="{{ base }} overflow-hidden bg-softblue-500" aria-hidden="true">
        <span class="absolute inset-1.5 rounded-lg border-2 border-white/50"></span>
        <span class="absolute inset-2.5 rounded-md"
              style="background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.55) 0 3px, transparent 3px 9px), repeating-linear-gradient(-45deg, rgba(255,255,255,0.55) 0 3px, transparent 3px 9px);"></span>
        <span class="absolute inset-0 flex items-center justify-center">
            <span class="size-3.5 rotate-45 rounded-sm bg-white shadow-sm"></span>
        </span>
    </span>
{% elseif joker|default(false) %}
    <span{{ attrs }} class="{{ base }} items-center justify-center bg-white text-sunny-500">
        {% include 'icons/star.svg.twig' with { class: 'size-8' } only %}
        <span class="mt-0.5 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'card.joker'|trans }}</span>
    </span>
{% else %}
    {% set color = red ? 'text-terracotta-500' : 'text-warmgray-800' %}
    {% set label = ('card.rank.' ~ rank)|trans %}
    <span{{ attrs }} class="{{ base }} bg-white {{ color }}" role="img" aria-label="{{ label }}{{ suit }}">
        <span class="absolute left-1.5 top-1 text-sm font-extrabold leading-tight">{{ label }}<br>{{ suit }}</span>
        <span class="absolute inset-0 flex items-center justify-center text-3xl">{{ suit }}</span>
        <span class="absolute bottom-1 right-1.5 rotate-180 text-sm font-extrabold leading-tight">{{ label }}<br>{{ suit }}</span>
    </span>
{% endif %}
