<div class="rounded-3xl bg-white p-5 shadow-soft">
    <h3 class="text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'log.title'|trans }}</h3>
    {% if lobby.state is null or lobby.state.log is empty %}
        <p class="mt-3 text-sm font-semibold text-warmgray-300">{{ 'log.empty'|trans }}</p>
    {% else %}
        <ol class="mt-3 max-h-80 space-y-1.5 overflow-y-auto pr-1 text-sm font-semibold text-warmgray-500">
            {% for entry in lobby.state.log %}
                {# Params prefixed with "t:" are translation keys themselves ("t:domain:key" for non-"messages" domains). #}
                {% set params = {} %}
                {% for key, value in entry.params %}
                    {% if (value ~ '') starts with 't:' %}
                        {% set rest = (value ~ '')|slice(2) %}
                        {% set value = ':' in rest
                            ? rest|split(':', 2)|last|trans({}, rest|split(':', 2)|first)
                            : rest|trans %}
                    {% endif %}
                    {% set params = params|merge({(key): value}) %}
                {% endfor %}
                <li class="rounded-xl bg-cream px-3 py-1.5 {{ loop.first ? 'text-warmgray-700 ring-1 ring-warmgray-200' }}">
                    {{ entry.key|trans(params, entry.domain|default('messages')) }}
                </li>
            {% endfor %}
        </ol>
    {% endif %}
</div>
