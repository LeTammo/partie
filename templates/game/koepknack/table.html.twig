{% trans_default_domain 'koepknack' %}
<div class="space-y-6">
    {# ---------- players & lives ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            <div class="rounded-2xl bg-cream px-4 py-2.5 text-center transition {{ p.current ? 'ring-2 ring-softblue-300' }} {{ p.eliminated ? 'opacity-40' }}">
                <p class="flex items-center justify-center gap-1.5 text-base font-extrabold text-warmgray-700">
                    <span class="size-2.5 rounded-full" style="background-color: {{ p.color }}"></span>
                    {{ p.nickname }}
                </p>
                <p class="mt-1.5 flex justify-center gap-1">
                    {% for i in 1..3 %}
                        <span class="size-2.5 rounded-full {{ i <= p.lives ? 'bg-terracotta-400' : 'bg-warmgray-200' }}"></span>
                    {% endfor %}
                </p>
                {% if p.eliminated %}
                    <p class="mt-1 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'koepknack.out'|trans }}</p>
                {% elseif p.swimming %}
                    <p class="mt-1 text-xs font-extrabold uppercase tracking-wide text-softblue-500">{{ 'koepknack.swimming'|trans }}</p>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {% if view.closed %}
        <p class="anim-rise rounded-2xl bg-sunny-100 px-4 py-2.5 text-center text-base font-extrabold text-warmgray-700">
            {{ 'koepknack.closed_by'|trans({'%player%': view.closerName}) }}
        </p>
    {% endif %}

    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="space-y-6">
        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">

        {# ---------- middle cards ---------- #}
        <div class="rounded-3xl bg-cream p-5">
            <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">
                {{ 'koepknack.round'|trans({'%round%': view.round}) }} · {{ 'koepknack.middle'|trans }}
            </p>
            <div class="flex justify-center gap-3">
                {% for card in view.middle %}
                    {% set identity = card.joker ? 'joker' : card.rank ~ '-' ~ card.suit %}
                    <label class="{{ view.canAct ? 'cursor-pointer' }}">
                        <input type="radio" name="middle" value="{{ loop.index0 }}" class="peer sr-only"
                               {% if not view.canAct %}disabled{% endif %}>
                        <span class="block rounded-xl transition peer-checked:-translate-y-1.5 peer-checked:ring-4 peer-checked:ring-softblue-300">
                            {% include 'components/card.html.twig' with card|merge({
                                key: 'kk-mid-' ~ loop.index0 ~ '-' ~ identity,
                                flip: 'kk-' ~ identity,
                                exit: ['fly-left', 'fade', 'fly-right'][loop.index0 % 3],
                            }) only %}
                        </span>
                    </label>
                {% endfor %}
            </div>
        </div>

        {# ---------- own hand ---------- #}
        {% if view.hand is not null %}
            <div>
                <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">
                    {{ 'koepknack.your_hand'|trans }} · {{ 'koepknack.value'|trans({'%value%': view.handValue}) }}
                </p>
                <div class="flex justify-center gap-3">
                    {% for card in view.hand %}
                        {% set identity = card.joker ? 'joker' : card.rank ~ '-' ~ card.suit %}
                        <label class="{{ view.canAct ? 'cursor-pointer' }}">
                            <input type="radio" name="hand" value="{{ loop.index0 }}" class="peer sr-only"
                                   {% if not view.canAct %}disabled{% endif %}>
                            <span class="block rounded-xl transition peer-checked:-translate-y-1.5 peer-checked:ring-4 peer-checked:ring-sage-300">
                                {% include 'components/card.html.twig' with card|merge({
                                    key: 'kk-hand-' ~ loop.index0 ~ '-' ~ identity,
                                    flip: 'kk-' ~ identity,
                                    exit: ['fly-right', 'fade', 'fly-left'][loop.index0 % 3],
                                }) only %}
                            </span>
                        </label>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# ---------- actions ---------- #}
        {% if view.canAct %}
            <div class="flex flex-wrap justify-center gap-3">
                <button type="submit" name="action" value="swap"
                        class="rounded-2xl bg-terracotta-300 px-7 py-3 text-lg font-extrabold text-white shadow-soft transition hover:bg-terracotta-200 hover:text-terracotta-700 hover:shadow-lifted">
                    {{ 'koepknack.swap'|trans }}
                </button>
                <button type="submit" name="action" value="swapall"
                        class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-warmgray-700 shadow-soft transition hover:shadow-lifted">
                    {{ 'koepknack.swap_all'|trans }}
                </button>
                <button type="submit" name="action" value="pass"
                        class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-warmgray-700 shadow-soft transition hover:shadow-lifted">
                    {{ 'koepknack.pass'|trans }}
                </button>
                {% if view.canClose %}
                    <button type="submit" name="action" value="close"
                            class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-softblue-500 shadow-soft transition hover:shadow-lifted">
                        {{ 'koepknack.close'|trans }}
                    </button>
                {% endif %}
            </div>
        {% endif %}
    </form>
</div>
