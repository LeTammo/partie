{% trans_default_domain 'blackjack' %}
<div class="space-y-6">
    {# ---------- dealer ---------- #}
    <div class="rounded-3xl bg-cream p-5">
        <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">
            {{ 'blackjack.round'|trans({'%round%': view.round, '%total%': view.roundsTotal}) }} · {{ 'blackjack.dealer'|trans }}
            {% if view.dealerUpValue is not null %}· {{ 'blackjack.shows'|trans({'%value%': view.dealerUpValue}) }}{% endif %}
        </p>
        <div class="flex justify-center gap-3">
            {% if view.dealer is empty %}
                {% include 'components/card.html.twig' with {back: true, class: 'opacity-40'} only %}
                {% include 'components/card.html.twig' with {back: true, class: 'opacity-40'} only %}
            {% else %}
                {% for card in view.dealer %}
                    {% include 'components/card.html.twig' with card only %}
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# ---------- players ---------- #}
    <div class="grid gap-3 sm:grid-cols-2 {{ view.players|length > 2 ? 'lg:grid-cols-3' }}">
        {% for p in view.players %}
            <div class="rounded-3xl bg-white p-4 shadow-soft {{ p.current ? 'ring-2 ring-softblue-300' }} {{ p.broke ? 'opacity-40' }}">
                <div class="flex items-center justify-between gap-2">
                    <p class="flex items-center gap-1.5 text-base font-extrabold text-warmgray-700">
                        <span class="size-2.5 rounded-full" style="background-color: {{ p.color }}"></span>
                        {{ p.nickname }}
                    </p>
                    <p class="flex items-center gap-1 text-base font-extrabold text-warmgray-500">
                        {% include 'icons/chip.svg.twig' with {class: 'size-4'} only %}
                        {{ p.chips }}
                    </p>
                </div>
                <div class="mt-3 flex min-h-24 flex-wrap gap-2">
                    {% for card in p.cards %}
                        {% include 'components/card.html.twig' with card only %}
                    {% else %}
                        <p class="self-center text-sm font-bold text-warmgray-300">
                            {{ p.broke ? 'blackjack.broke'|trans : 'blackjack.waiting'|trans }}
                        </p>
                    {% endfor %}
                </div>
                <div class="mt-2 flex items-center justify-between text-sm font-extrabold">
                    <span class="text-warmgray-400">
                        {% if p.bet is not null %}{{ 'blackjack.bet_label'|trans({'%amount%': p.bet}) }}{% endif %}
                    </span>
                    {% if p.bust %}
                        <span class="text-terracotta-500">{{ 'blackjack.bust'|trans }}</span>
                    {% elseif p.blackjack %}
                        <span class="text-sunny-500">{{ 'blackjack.blackjack'|trans }}</span>
                    {% elseif p.value is not null %}
                        <span class="text-warmgray-600">{{ p.value }}</span>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {# ---------- actions ---------- #}
    {% if view.myTurn %}
        <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="flex flex-wrap justify-center gap-3">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            {% if view.phase == 'betting' %}
                <input type="hidden" name="action" value="bet">
                {% for amount in view.betOptions %}
                    <button type="submit" name="amount" value="{{ amount }}"
                            class="inline-flex items-center gap-2 rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-warmgray-700 shadow-soft transition hover:shadow-lifted">
                        {% include 'icons/chip.svg.twig' with {class: 'size-4'} only %}
                        {{ amount }}
                    </button>
                {% endfor %}
            {% else %}
                <button type="submit" name="action" value="hit"
                        class="rounded-2xl bg-terracotta-300 px-7 py-3 text-lg font-extrabold text-white shadow-soft transition hover:bg-terracotta-200 hover:text-terracotta-700 hover:shadow-lifted">
                    {{ 'blackjack.hit'|trans }}
                </button>
                <button type="submit" name="action" value="stand"
                        class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-warmgray-700 shadow-soft transition hover:shadow-lifted">
                    {{ 'blackjack.stand'|trans }}
                </button>
                {% if view.canDouble %}
                    <button type="submit" name="action" value="double"
                            class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-softblue-500 shadow-soft transition hover:shadow-lifted">
                        {{ 'blackjack.double'|trans }}
                    </button>
                {% endif %}
            {% endif %}
        </form>
    {% endif %}
</div>
