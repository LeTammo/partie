{% trans_default_domain 'maumau' %}
<div class="space-y-6" data-controller="maumau">
    {# ---------- players ---------- #}
    <div class="flex flex-wrap justify-center gap-3">
        {% for p in view.players %}
            <div class="flex items-center gap-2 rounded-2xl bg-cream px-4 py-2.5 transition {{ p.current ? 'ring-2 ring-softblue-300' }}">
                <span class="size-2.5 rounded-full" style="background-color: {{ p.color }}"></span>
                <span class="text-base font-extrabold text-warmgray-700">{{ p.nickname }}</span>
                <span class="inline-flex items-center gap-1 text-sm font-extrabold text-warmgray-400">
                    {% include 'icons/card-fan.svg.twig' with {class: 'size-4'} only %}
                    {{ p.cardCount }}
                </span>
            </div>
        {% endfor %}
    </div>

    {# ---------- table: draw pile + discard ---------- #}
    <div class="rounded-3xl bg-cream p-5">
        <div class="flex items-center justify-center gap-6">
            <div class="text-center">
                <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                    <input type="hidden" name="action" value="draw">
                    <button type="submit" {% if not view.canDraw %}disabled{% endif %}
                            class="block rounded-xl transition enabled:hover:-translate-y-1 enabled:hover:shadow-lifted disabled:opacity-60"
                            title="{{ 'maumau.draw'|trans }}">
                        {% include 'components/card.html.twig' with {back: true} only %}
                    </button>
                </form>
                <p class="mt-1.5 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">
                    {{ 'maumau.pile'|trans({'%count%': view.drawCount}) }}
                </p>
            </div>
            <div class="text-center" data-maumau-target="dropzone"
                 data-action="dragover->maumau#dragOver drop->maumau#drop dragleave->maumau#dragLeave">
                {% set topIdentity = view.top.joker ? 'joker' : view.top.rank ~ '-' ~ view.top.suit %}
                {% include 'components/card.html.twig' with view.top|merge({
                    key: 'mm-top-' ~ topIdentity,
                    flip: 'mm-' ~ topIdentity,
                    exit: 'none',
                }) only %}
                <p class="mt-1.5 text-xs font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'maumau.discard'|trans }}</p>
            </div>
        </div>

        <div class="mt-3 flex flex-wrap items-center justify-center gap-3 text-base font-extrabold">
            {% if view.wishedSuit is not null %}
                <span class="anim-pop rounded-xl bg-white px-3 py-1.5 shadow-soft {{ view.wishedSuitRed ? 'text-terracotta-500' : 'text-warmgray-800' }}">
                    {{ 'maumau.wished'|trans }} {{ view.wishedSuit }}
                </span>
            {% endif %}
            {% if view.pendingDraw > 0 %}
                <span id="pending-draw-{{ view.pendingDraw }}" class="anim-pop rounded-xl bg-terracotta-100 px-3 py-1.5 text-terracotta-700 shadow-soft">
                    {{ 'maumau.pending_draw'|trans({'%count%': view.pendingDraw}) }}
                </span>
            {% endif %}
        </div>
    </div>

    {# ---------- own hand ---------- #}
    {% if view.hand is not empty %}
        <div>
            <p class="mb-3 text-center text-sm font-extrabold uppercase tracking-wide text-warmgray-400">{{ 'maumau.your_hand'|trans }}</p>
            <div class="flex flex-wrap justify-center gap-3">
                {% for card in view.hand %}
                    {% set identity = card.joker ? 'joker' : card.rank ~ '-' ~ card.suit %}
                    <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="text-center"
                          data-maumau-target="cardForm" data-index="{{ card.index }}"
                          {% if card.isJack %}data-jack="true"{% endif %}>
                        <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                        <input type="hidden" name="action" value="play">
                        <input type="hidden" name="card" value="{{ card.index }}">
                        <button type="{{ card.isJack ? 'button' : 'submit' }}"
                                {% if not card.playable %}disabled{% endif %}
                                {% if card.playable %}
                                    draggable="true"
                                    data-action="dragstart->maumau#dragStart dragend->maumau#dragEnd{{ card.isJack ? ' click->maumau#play' }}"
                                {% endif %}
                                class="block rounded-xl transition enabled:cursor-grab enabled:hover:-translate-y-1.5 enabled:hover:shadow-lifted
                                       {{ not card.playable and view.myTurn ? 'opacity-40' }}
                                       {{ card.playable and card.isJack ? 'ring-2 ring-sunny-300' }}">
                            {% include 'components/card.html.twig' with card|merge({
                                key: 'mm-hand-' ~ identity,
                                flip: 'mm-' ~ identity,
                                exit: 'none',
                            }) only %}
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ---------- actions ---------- #}
    {% if view.canPass %}
        <form method="post" action="{{ path('app_game_move', {code: lobby.code}) }}" class="text-center">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            <input type="hidden" name="action" value="pass">
            <button type="submit" class="rounded-2xl bg-white px-7 py-3 text-lg font-extrabold text-warmgray-700 shadow-soft transition hover:shadow-lifted">
                {{ 'maumau.pass'|trans }}
            </button>
        </form>
    {% endif %}

    {# ---------- wish suit dialog ---------- #}
    <dialog data-maumau-target="dialog" data-action="close->maumau#dialogClosed"
            class="m-auto rounded-3xl bg-white p-6 text-center shadow-lifted backdrop:bg-warmgray-800/40">
        <p class="text-lg font-extrabold text-warmgray-700">{{ 'maumau.wish_prompt'|trans }}</p>
        <div class="mt-4 flex justify-center gap-3">
            {% for suit in view.suits %}
                <button type="button" data-action="maumau#wish" data-suit="{{ suit.value }}"
                        title="{{ 'maumau.wish'|trans }} {{ suit.symbol }}"
                        class="grid size-14 place-items-center rounded-2xl bg-cream text-3xl font-extrabold shadow-soft transition hover:shadow-lifted
                               {{ suit.red ? 'text-terracotta-500' : 'text-warmgray-800' }}">
                    {{ suit.symbol }}
                </button>
            {% endfor %}
        </div>
    </dialog>
</div>
